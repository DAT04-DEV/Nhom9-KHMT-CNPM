FLASK_ENV=development
FLASK_DEBUG=1

# Supabase Postgres connection string.
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=fraud-detection-app
JWT_EXPIRES_MINUTES=120

# Required to create admin accounts from the public register endpoint.
ADMIN_INVITE_CODE=change-me-admin-code

# Set to true only when serving over HTTPS.
COOKIE_SECURE=false
